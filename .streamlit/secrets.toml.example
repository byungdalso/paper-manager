# ============================================================================
# secrets.toml.example
# ----------------------------------------------------------------------------
# 이 파일은 TEMPLATE 입니다.
#
# 로컬에서 돌릴 때:
#   이 파일을 같은 폴더의 secrets.toml 로 복사하고 실제 값을 채우세요.
#   .streamlit/secrets.toml 은 .gitignore 로 제외되어 있어 커밋되지 않습니다.
#
# Streamlit Cloud 에 배포할 때:
#   앱 설정 → Secrets 창에 아래 내용(값 채운 버전)을 그대로 붙여넣으세요.
# ============================================================================

# ── 로그인 비밀번호 ──────────────────────────────────────────────────────────
admin_password = "여기에_관리자_비밀번호"
view_password  = "여기에_학생용_비밀번호"

# ── Supabase ────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API 에서 복사
#   - Project URL : 프로젝트 메인 URL
#   - service_role: "Reveal" 클릭해서 나오는 긴 JWT 문자열
#                   (anon 키 아님! service_role 을 써야 함)
supabase_url         = "https://xxxxxxxxxxxx.supabase.co"
supabase_service_key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.여기는_아주_긴_JWT_문자열"
